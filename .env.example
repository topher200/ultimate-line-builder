# Copy to .env to enable Supabase cloud sync. Fill in from the Supabase
# dashboard: Project Settings > API.
#
# Use the PUBLISHABLE (anon) key. It is safe to ship in the web client and is
# gated by row-level security. NEVER put the SECRET key here -- it would end up
# in the browser bundle and bypass all security.

VITE_SUPABASE_URL=https://citadbfcwnfclumiyqxt.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
